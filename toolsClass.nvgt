#include "inventoryInterface.nvgt"
class Tools:IInventoryItems{
    string name;
    int quantity;
    Tools(string name,int quantity){
this.name=name;
this.quantity=quantity;
    }
string get_string(){
    return string(quantity+name);
}
string getName(){
    return name;
}
int getQuantity(){
return quantity;
}
void setQuantity(int q){
    quantity=q;
}
}
